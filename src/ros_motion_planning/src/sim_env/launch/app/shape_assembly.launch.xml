  <arg name="shape_target_mode" default="USE_YAML_SENTINEL" />
  <arg name="shape_marker_mode" default="USE_YAML_SENTINEL" />

  <arg name="control_hz" default="USE_YAML_SENTINEL" />
  <arg name="control_dt" default="USE_YAML_SENTINEL" />
  <arg name="sim_dt" default="USE_YAML_SENTINEL" />
  <arg name="vel_max" default="USE_YAML_SENTINEL" />
  <arg name="leader_fraction" default="USE_YAML_SENTINEL" />
