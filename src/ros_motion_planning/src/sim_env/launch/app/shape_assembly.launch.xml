  <arg name="node_name" default="shape_assembly_swarm" />
  <arg name="enabled" default="USE_YAML_SENTINEL" />
  <arg name="auto_detect" default="USE_YAML_SENTINEL" />
  <arg name="namespace_prefix" default="USE_YAML_SENTINEL" />
  <arg name="agent_number" default="USE_YAML_SENTINEL" />
  <arg name="distributed_mode" default="USE_YAML_SENTINEL" />
  <arg name="distributed_agent_namespace" default="USE_YAML_SENTINEL" />
  <arg name="distributed_marker_owner" default="USE_YAML_SENTINEL" />
  <arg name="robot_odom_topic_suffix" default="USE_YAML_SENTINEL" />
  <arg name="marker_topic" default="USE_YAML_SENTINEL" />

  <arg name="shape_source" default="USE_YAML_SENTINEL" />
  <arg name="shape_type" default="USE_YAML_SENTINEL" />
