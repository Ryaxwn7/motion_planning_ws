    <param if="$(eval arg('cancel_move_base_on_switch') != 'USE_YAML_SENTINEL')" name="cancel_move_base_on_switch" value="$(arg cancel_move_base_on_switch)" />
    <param if="$(eval arg('cancel_grace_period') != 'USE_YAML_SENTINEL')" name="cancel_grace_period" value="$(arg cancel_grace_period)" />
