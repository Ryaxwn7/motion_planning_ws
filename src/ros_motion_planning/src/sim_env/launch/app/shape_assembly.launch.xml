  <arg name="auto_shape_heading" default="USE_YAML_SENTINEL" />
  <arg name="auto_shape_heading_map_topic" default="USE_YAML_SENTINEL" />
  <arg name="auto_shape_heading_angle_step_deg" default="USE_YAML_SENTINEL" />
  <arg name="auto_shape_heading_update_interval" default="USE_YAML_SENTINEL" />
  <arg name="auto_shape_heading_obstacle_threshold" default="USE_YAML_SENTINEL" />
