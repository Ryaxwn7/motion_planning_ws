  <arg name="publish_markers" default="USE_YAML_SENTINEL" />
  <arg name="debug_log" default="USE_YAML_SENTINEL" />

  <node pkg="sim_env" type="shape_assembly_swarm.py" name="$(arg node_name)" output="screen">
    <!-- Launch fallback defaults (lowest priority). -->
    <rosparam>
      enabled: true
      auto_detect: true
      namespace_prefix: robot
      agent_number: 0
      distributed_mode: false
      distributed_agent_namespace: ""
      distributed_marker_owner: ""
      robot_odom_topic_suffix: /odom
      shape_source: mat
      shape_type: starfish
      formation_task_topic: /shape_assembly/task
      robot_status_topic: shape_assembly/status
      control_hz: 50.0
      control_dt: 0.0
      vel_max: 0.5
      control_strategy: shape_only
      shape_target_mode: negotiated
      shape_marker_mode: negotiated
      marker_topic: /shape_assembly/markers
      use_local_costmap_avoid: true
      local_costmap_topic_suffix: move_base/local_costmap/costmap
      local_costmap_obstacle_threshold: 80
      local_costmap_unknown_is_obstacle: false
      local_costmap_avoid_radius: 0.8
      local_costmap_avoid_gain: 18.0
      local_costmap_hard_radius: 0.5
      local_costmap_hard_gain: 35.0
      local_costmap_stride: 1
      local_costmap_max_samples: 500
      local_costmap_timeout: 1.0
      local_costmap_self_ignore_radius: 0.28
      local_costmap_skip_on_frame_mismatch: true
      cancel_grace_period: 0.0
      auto_shape_heading: false
      auto_shape_heading_map_topic: /map
      auto_shape_heading_angle_step_deg: 15.0
      auto_shape_heading_update_interval: 0.5
      auto_shape_heading_obstacle_threshold: 80
      auto_shape_heading_unknown_is_obstacle: true
      auto_shape_heading_shape_stride: 2
      auto_shape_heading_min_improve: 0.01
      auto_shape_heading_yaw_bias: 0.02
      auto_shape_heading_oob_is_obstacle: true
      publish_markers: true
      debug_log: true
    </rosparam>

    <!-- YAML config (middle priority). -->
    <rosparam file="$(find sim_env)/config/shape_assembly.yaml" command="load" />

    <!-- Command-line overrides (highest priority). -->
    <param if="$(eval arg('enabled') != 'USE_YAML_SENTINEL')" name="enabled" value="$(arg enabled)" />
    <param if="$(eval arg('auto_detect') != 'USE_YAML_SENTINEL')" name="auto_detect" value="$(arg auto_detect)" />
    <param if="$(eval arg('namespace_prefix') != 'USE_YAML_SENTINEL')" name="namespace_prefix" value="$(arg namespace_prefix)" />
