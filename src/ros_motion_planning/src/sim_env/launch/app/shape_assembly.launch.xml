    <param if="$(eval arg('local_costmap_topic_suffix') != 'USE_YAML_SENTINEL')" name="local_costmap_topic_suffix" value="$(arg local_costmap_topic_suffix)" />
    <param if="$(eval arg('local_costmap_obstacle_threshold') != 'USE_YAML_SENTINEL')" name="local_costmap_obstacle_threshold" value="$(arg local_costmap_obstacle_threshold)" />
