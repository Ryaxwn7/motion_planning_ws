    <param if="$(eval arg('switch_reference_radius_enable') != 'USE_YAML_SENTINEL')" name="switch_reference_radius_enable" value="$(arg switch_reference_radius_enable)" />
    <param if="$(eval arg('switch_reference_radius_margin') != 'USE_YAML_SENTINEL')" name="switch_reference_radius_margin" value="$(arg switch_reference_radius_margin)" />
    <param if="$(eval arg('switch_reference_radius_min') != 'USE_YAML_SENTINEL')" name="switch_reference_radius_min" value="$(arg switch_reference_radius_min)" />

