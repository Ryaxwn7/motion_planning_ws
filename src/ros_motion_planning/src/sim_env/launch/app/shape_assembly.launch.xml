    <param if="$(eval arg('ring_outer_ratio') != 'USE_YAML_SENTINEL')" name="ring_outer_ratio" value="$(arg ring_outer_ratio)" />
    <param if="$(eval arg('gray_width') != 'USE_YAML_SENTINEL')" name="gray_width" value="$(arg gray_width)" />
