    <param if="$(eval arg('auto_shape_heading_shape_stride') != 'USE_YAML_SENTINEL')" name="auto_shape_heading_shape_stride" value="$(arg auto_shape_heading_shape_stride)" />
    <param if="$(eval arg('auto_shape_heading_min_improve') != 'USE_YAML_SENTINEL')" name="auto_shape_heading_min_improve" value="$(arg auto_shape_heading_min_improve)" />
    <param if="$(eval arg('auto_shape_heading_yaw_bias') != 'USE_YAML_SENTINEL')" name="auto_shape_heading_yaw_bias" value="$(arg auto_shape_heading_yaw_bias)" />
    <param if="$(eval arg('auto_shape_heading_oob_is_obstacle') != 'USE_YAML_SENTINEL')" name="auto_shape_heading_oob_is_obstacle" value="$(arg auto_shape_heading_oob_is_obstacle)" />

