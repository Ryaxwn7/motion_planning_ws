    <param if="$(eval arg('local_costmap_avoid_radius') != 'USE_YAML_SENTINEL')" name="local_costmap_avoid_radius" value="$(arg local_costmap_avoid_radius)" />
    <param if="$(eval arg('local_costmap_avoid_gain') != 'USE_YAML_SENTINEL')" name="local_costmap_avoid_gain" value="$(arg local_costmap_avoid_gain)" />
    <param if="$(eval arg('local_costmap_hard_radius') != 'USE_YAML_SENTINEL')" name="local_costmap_hard_radius" value="$(arg local_costmap_hard_radius)" />
    <param if="$(eval arg('local_costmap_hard_gain') != 'USE_YAML_SENTINEL')" name="local_costmap_hard_gain" value="$(arg local_costmap_hard_gain)" />
    <param if="$(eval arg('local_costmap_stride') != 'USE_YAML_SENTINEL')" name="local_costmap_stride" value="$(arg local_costmap_stride)" />
    <param if="$(eval arg('local_costmap_max_samples') != 'USE_YAML_SENTINEL')" name="local_costmap_max_samples" value="$(arg local_costmap_max_samples)" />
