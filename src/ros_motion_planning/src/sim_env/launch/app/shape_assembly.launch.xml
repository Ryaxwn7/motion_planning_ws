    <param if="$(eval arg('reference_center_use_topic_heading') != 'USE_YAML_SENTINEL')" name="reference_center_use_topic_heading" value="$(arg reference_center_use_topic_heading)" />
    <param if="$(eval arg('control_strategy') != 'USE_YAML_SENTINEL')" name="control_strategy" value="$(arg control_strategy)" />
    <param if="$(eval arg('shape_target_mode') != 'USE_YAML_SENTINEL')" name="shape_target_mode" value="$(arg shape_target_mode)" />
    <param if="$(eval arg('shape_marker_mode') != 'USE_YAML_SENTINEL')" name="shape_marker_mode" value="$(arg shape_marker_mode)" />

    <param if="$(eval arg('control_hz') != 'USE_YAML_SENTINEL')" name="control_hz" value="$(arg control_hz)" />
    <param if="$(eval arg('control_dt') != 'USE_YAML_SENTINEL')" name="control_dt" value="$(arg control_dt)" />
    <param if="$(eval arg('sim_dt') != 'USE_YAML_SENTINEL')" name="sim_dt" value="$(arg sim_dt)" />
    <param if="$(eval arg('vel_max') != 'USE_YAML_SENTINEL')" name="vel_max" value="$(arg vel_max)" />
    <param if="$(eval arg('leader_fraction') != 'USE_YAML_SENTINEL')" name="leader_fraction" value="$(arg leader_fraction)" />
    <param if="$(eval arg('kappa_enter') != 'USE_YAML_SENTINEL')" name="kappa_enter" value="$(arg kappa_enter)" />
    <param if="$(eval arg('kappa_explore_1') != 'USE_YAML_SENTINEL')" name="kappa_explore_1" value="$(arg kappa_explore_1)" />
    <param if="$(eval arg('kappa_explore_2') != 'USE_YAML_SENTINEL')" name="kappa_explore_2" value="$(arg kappa_explore_2)" />
    <param if="$(eval arg('kappa_avoid') != 'USE_YAML_SENTINEL')" name="kappa_avoid" value="$(arg kappa_avoid)" />
    <param if="$(eval arg('kappa_hard_avoid') != 'USE_YAML_SENTINEL')" name="kappa_hard_avoid" value="$(arg kappa_hard_avoid)" />
    <param if="$(eval arg('kappa_consensus') != 'USE_YAML_SENTINEL')" name="kappa_consensus" value="$(arg kappa_consensus)" />
    <param if="$(eval arg('kappa_conse_pos') != 'USE_YAML_SENTINEL')" name="kappa_conse_pos" value="$(arg kappa_conse_pos)" />
    <param if="$(eval arg('kappa_track_pos') != 'USE_YAML_SENTINEL')" name="kappa_track_pos" value="$(arg kappa_track_pos)" />
    <param if="$(eval arg('kappa_conse_head') != 'USE_YAML_SENTINEL')" name="kappa_conse_head" value="$(arg kappa_conse_head)" />
    <param if="$(eval arg('kappa_track_head') != 'USE_YAML_SENTINEL')" name="kappa_track_head" value="$(arg kappa_track_head)" />
